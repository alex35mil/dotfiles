theme = hyper
macos-icon = blueprint

font-family = "BerkeleyMono Nerd Font"
font-family-bold = "BerkeleyMono Nerd Font Bold"
font-family-italic = "BerkeleyMono Nerd Font Oblique"
font-family-bold-italic = "BerkeleyMono Nerd Font Bold Oblique"

font-size = 16
font-thicken = false
adjust-cell-height = 40%
adjust-box-thickness = -3

window-decoration = auto
window-padding-x = 20
window-padding-y = 20
window-width = 226
window-height = 64
window-position-x = 128
window-position-y = 73
macos-titlebar-style = hidden

minimum-contrast = 1.1

cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

copy-on-select = clipboard
clipboard-paste-protection = true

