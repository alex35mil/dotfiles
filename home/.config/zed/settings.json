{
    "base_keymap": "None",
    "ui_font_family": "BerkeleyMono Nerd Font",
    "buffer_font_family": "BerkeleyMono Nerd Font",
    "buffer_font_size": 17,
    "buffer_line_height": { "custom": 2 },
    "tab_size": 4,
    "preferred_line_length": 100,
    "show_wrap_guides": true,
    "wrap_guides": [80, 120],
    "autosave": "on_focus_change",
    "auto_update": true,
    "ensure_final_newline_on_save": true,
    "remove_trailing_whitespace_on_save": true,
    "format_on_save": "on",
    "close_on_file_delete": true,
    "current_line_highlight": "all",
    "cursor_blink": false,
    "vertical_scroll_margin": 0,
    "active_pane_modifiers": {
        "inactive_opacity": 0.8
    },
    "multi_cursor_modifier": "cmd_or_ctrl",
    "use_autoclose": true,
    "always_treat_brackets_as_autoclosed": false,
    "when_closing_with_no_tabs": "keep_window_open",
    "hover_popover_enabled": false,
    "hide_mouse": "on_typing_and_movement",
    "show_edit_predictions": true,
    "scrollbar": {
        "show": "auto",
        "cursors": true,
        "git_diff": true,
        "search_results": true,
        "selected_text": true,
        "selected_symbol": true,
        "diagnostics": "warning",
        "axes": {
            "horizontal": true,
            "vertical": true
        }
    },
    "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "edit_debounce_ms": 700,
        "scroll_debounce_ms": 50
    },
    "indent_guides": {
        "enabled": true,
        "line_width": 1,
        "coloring": "fixed",
        "background_coloring": "disabled"
    },
    "tab_bar": {
        "show": false
    },
    "toolbar": {
        "breadcrumbs": true,
        "quick_actions": true,
        "selections_menu": false,
        "agent_review": true,
        "code_actions": false
    },
    "centered_layout": {
        // - small screen
        "left_padding": 0.1,
        "right_padding": 0.1
        // - big screen
        // "left_padding": 0.15,
        // "right_padding": 0.15
    },
    "preview_tabs": {
        "enabled": true,
        "enable_preview_from_file_finder": true,
        "enable_preview_from_code_navigation": true
    },
    "file_finder": {
        "modal_max_width": "medium",
        "skip_focus_for_active_in_search": true
    },
    "load_direnv": "shell_hook",
    "vim_mode": true,
    "vim": {
        "use_system_clipboard": "on_yank",
        "use_multiline_find": true,
        "use_smartcase_find": true
    },
    "git": {
        "git_gutter": "tracked_files",
        "inline_blame": {
            "enabled": false
        }
    },
    "diagnostics": {
        "inline": {
            "enabled": true,
            "update_debounce_ms": 150,
            "padding": 4,
            "min_column": 0,
            "max_severity": "warning"
        }
    },
    "project_panel": {
        "button": true,
        "dock": "left",
        "file_icons": true,
        "folder_icons": true,
        "git_status": true,
        "indent_size": 20,
        "auto_reveal_entries": true,
        "auto_fold_dirs": false,
        "default_width": 240,
        "entry_spacing": "comfortable",
        "show_diagnostics": "all",
        "indent_guides": {
            "show": "always"
        }
    },
    "collaboration_panel": {
        "dock": "right"
    },
    "outline_panel": {
        "dock": "left"
    },
    "completions": {
        "words": "enabled",
        "lsp": true,
        "lsp_fetch_timeout_ms": 0,
        "lsp_insert_mode": "replace_suffix"
    },
    "agent": {
        "default_profile": "write",
        "inline_assistant_model": {
            "provider": "anthropic",
            "model": "claude-sonnet-4-latest"
        },
        "single_file_review": true,
        "always_allow_tool_actions": true,
        "default_model": {
            "provider": "anthropic",
            "model": "claude-sonnet-4-thinking-latest"
        },
        "version": "2"
    },
    "terminal": {
        "alternate_scroll": "off",
        "blinking": "off",
        "copy_on_select": true,
        "option_as_meta": false,
        "button": true,
        "toolbar": {
            "title": true
        },
        "working_directory": "current_project_directory"
    },
    "lsp": {
        "rust-analyzer": {
            "initialization_options": {
                "check": {
                    "command": "clippy"
                }
            }
        }
    },
    "languages": {
        "JSON": {
            "format_on_save": "off"
        },
        "TOML": {
            "format_on_save": "off"
        },
        "YAML": {
            "format_on_save": "off"
        },
        "Clojure": {
            "format_on_save": "off"
        },
        "Markdown": {
            "format_on_save": "off"
        }
    },

    "theme": "Ayu Mirage",
    "experimental.theme_overrides": {
        "background": "#272b30",

        // --- text
        "text": "#afb4c3",
        "text.muted": "#838994",
        "text.placeholder": "#686d75",
        "text.disabled": "#555a63",
        "text.accent": "#7fb2c8",

        // --- borders
        "border": "#2f3337",
        "border.variant": "#2f3337",
        "border.focused": "#2f3337",
        "border.selected": "#2f3337",
        "border.transparent": "#00000000",
        // "border.disabled": "#ff0000",

        // --- icons
        // "icon": "#ff0000",
        // "icon.muted": "#ff0000",
        // "icon.disabled": "#ff0000",
        // "icon.placeholder": "#ff0000",
        // "icon.accent": "#ff0000",

        // --- elements
        "element.background": "#3a3d43",
        "element.hover": "#363c46",
        "element.active": "#454a5680",
        "element.selected": "#454a5680",
        // "element.disabled": "#ff0000",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#454a5640",
        "ghost_element.active": "#454a5680",
        "ghost_element.selected": "#454a5680",
        // "ghost_element.disabled": "#ff0000",

        "drop_target.background": "#7fb2c880",

        // --- editor
        "editor.foreground": "#afb4c3",
        "editor.background": "#272b30",
        "editor.gutter.background": "#272b30",
        "editor.line_number": "#464b50",
        "editor.active_line_number": "#afb4c3aa",
        "editor.indent_guide": "#2f3337",
        "editor.indent_guide_active": "#404449",
        "search.match_background": "#7fb2c866",
        "editor.subheader.background": "#7fb2c830",
        "editor.active_line.background": "#2f343ebf",
        // "editor.highlighted_line.background": "#ff0000",
        "editor.invisible": "#696d76",
        "editor.wrap_guide": "#2f3337",
        "editor.active_wrap_guide": "#2f3337",
        "editor.document_highlight.read_background": "#7fb2c81a",
        "editor.document_highlight.write_background": "#7fb2c866",

        "link_text.hover": "#81a2be",

        // --- scrollbars
        "scrollbar.thumb.background": "#777b804c",
        // "scrollbar.thumb.hover_background": "#ff0000",
        "scrollbar.thumb.border": "#00000000",
        "scrollbar.track.background": "#00000000",
        "scrollbar.track.border": "#00000000",

        // --- panels
        "panel.background": "#272b30",
        "surface.background": "#272b30",
        "elevated_surface.background": "#2b2f34",

        // --- bars
        "status_bar.background": "#272b30",
        "title_bar.background": "#272b30",
        "tab_bar.background": "#272b30",
        "toolbar.background": "#272b30",

        // --- tabs
        "tab.active_background": "#272b30",
        "tab.inactive_background": "#2d3136",

        // --- statuses
        // "success": "#ff0000",
        // "success.background": "#ff0000",
        // "success.border": "#ff0000",

        // "hidden": "#ff0000",
        // "hidden.background": "#ff0000",
        // "hidden.border": "#ff0000",

        // --- git
        "created": "#bdb968",
        // "created.background": "#ff0000",
        // "created.border": "#ff0000",

        "modified": "#7fb2c8",
        // "modified.background": "#ff0000",
        // "modified.border": "#ff0000",

        // "renamed": "#ff0000",
        // "renamed.background": "#ff0000",
        // "renamed.border": "#ff0000",

        "deleted": "#cc6666",
        // "deleted.background": "#ff0000",
        // "deleted.border": "#ff0000",

        "ignored": "#555a63",
        // "ignored.background": "#ff0000",
        // "ignored.border": "#ff0000",

        // "conflict": "#ff0000",
        // "conflict.background": "#ff0000",
        // "conflict.border": "#ff0000"

        // --- diagnostics
        "hint": "#708090",
        "hint.background": "#18243d",
        "hint.border": "#18243d",

        "info": "#81a2be",
        // "info.background": "#ff0000",
        // "info.border": "#ff0000",

        "warning": "#f0c674",
        "warning.background": "#41321d",
        "warning.border": "#41321d",

        "error": "#cc6666",
        "error.background": "#301b1b",
        "error.border": "#301b1b",

        // --- intellisense
        "predictive": "#708090",
        // "predictive.background": "#ff0000",
        // "predictive.border": "#ff0000",

        "unreachable": "#f0c674",
        "unreachable.background": "#41321d",
        "unreachable.border": "#41321d",

        // termital
        "terminal.background": "#272b30",
        "terminal.foreground": "#afb4c3",
        "terminal.bright_foreground": "#ffffff",
        "terminal.dim_foreground": "#737b8c",
        "terminal.ansi.black": "#1c1c1c",
        "terminal.ansi.bright_black": "#636363",
        "terminal.ansi.dim_black": "#2e3236",
        "terminal.ansi.red": "#cc6666",
        "terminal.ansi.bright_red": "#a04041",
        "terminal.ansi.dim_red": "#993333",
        "terminal.ansi.green": "#bdb968",
        "terminal.ansi.bright_green": "#8b9440",
        "terminal.ansi.dim_green": "#7a7a3a",
        "terminal.ansi.yellow": "#f0c674",
        "terminal.ansi.bright_yellow": "#ec9c62",
        "terminal.ansi.dim_yellow": "#d1a345",
        "terminal.ansi.blue": "#81a2be",
        "terminal.ansi.bright_blue": "#5d7f9a",
        "terminal.ansi.dim_blue": "#597e8e",
        "terminal.ansi.magenta": "#b193ba",
        "terminal.ansi.bright_magenta": "#82658c",
        "terminal.ansi.dim_magenta": "#735b75",
        "terminal.ansi.cyan": "#7fb2c8",
        "terminal.ansi.bright_cyan": "#5e8d87",
        "terminal.ansi.dim_cyan": "#518b8b",
        "terminal.ansi.white": "#c8ccd4",
        "terminal.ansi.bright_white": "#ffffff",
        "terminal.ansi.dim_white": "#9aa1ab",

        "players": [
            {
                "cursor": "#afb4c3",
                // "background": "#ff0000",
                "selection": "#afb4c340"
            }
        ],

