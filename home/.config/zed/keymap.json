        "bindings": {
            // This is identical to the binding in the base keymap, but the vim bindings above to
            // "vim::Tab" shadow it, so it needs to be bound again.
            "tab": "editor::AcceptEditPrediction"
        }
    },
    {
        "context": "os != macos && Editor && edit_prediction_conflict",
        "bindings": {
            // alt-l is provided as an alternative to tab/alt-tab. and will be displayed in the UI. This
            // is because alt-tab may not be available, as it is often used for window switching on Linux
            // and Windows.
            "alt-l": "editor::AcceptEditPrediction"
        }
    },

    // --- Custom

    {
        "bindings": {
            "cmd-m": "workspace::ToggleZoom",
            "cmd-p": "command_palette::Toggle",
            "cmd-t": "file_finder::Toggle",
            "ctrl-escape": "workspace::ClearAllNotifications",
            "cmd-shift-f": "pane::DeploySearch",
            "cmd-shift-d": "diagnostics::Deploy",
            "cmd-shift-p": "projects::OpenRecent",
            "alt-q": "workspace::CloseWindow",
            // TODO: Revisit
            "cmd-shift-e": "workspace::ToggleLeftDock",
            "cmd-shift-a": "workspace::ToggleRightDock",
            "cmd-shift-t": "workspace::ToggleBottomDock",
            "cmd-shift-alt-t": "terminal_panel::ToggleFocus",
            "cmd-escape": "workspace::CloseAllDocks",
            "shift-alt-r": "workspace::Reload",
            "shift-alt-c": "workspace::ToggleCenteredLayout",
            "shift-alt-f": "zed::ToggleFullScreen"
        }
    },

    // Closing things on `⌘ W`
    {
        "context": "Picker",
        "bindings": {
            "cmd-w": "menu::Cancel"
        }
    },
    {
        "context": "Editor && (showing_completions || showing_code_actions)",
        "bindings": {
            "cmd-w": "editor::Cancel"
        }
    },
    {
        "context": "InlineAssistEditor",
        "bindings": {
            "cmd-w": "editor::Cancel"
        }
    },
    {
        "context": "BufferSearchBar",
        "bindings": {
            "cmd-w": "editor::Cancel"
        }
    },
    {
        "context": "ProjectPanel || GitPanel || OutlinePanel",
        "bindings": {
            "cmd-w": "workspace::ToggleLeftDock"
        }
    },

    // Editor
    {
        "context": "Editor && mode == full",
        "bindings": {
            "ctrl-up": "editor::AddSelectionAbove",
            "ctrl-down": "editor::AddSelectionBelow",
            "cmd-d": "editor::DuplicateLineDown",
            "cmd-f": ["buffer_search::Deploy", { "focus": true }],
            "cmd-h": ["buffer_search::Deploy", { "focus": false }],
            "cmd-shift-h": "editor::SelectAllMatches",
            "cmd-shift-n": "editor::SelectNext",
            "cmd-r": "editor::Rename",
            "cmd-u": "editor::FindAllReferences",
            "cmd-i": "editor::Hover",
            "cmd-o": "outline::Toggle",
            "g f": "editor::OpenExcerpts",
            "cmd-shift-j": "editor::OpenExcerptsSplit",
            "cmd-shift-o": "project_symbols::Toggle",
            "cmd-shift-i": "assistant::InlineAssist",
            "cmd-shift-l": "language_selector::Toggle",
            "shift-ctrl-r": "editor::RestartLanguageServer",
            "alt-c": "editor::ShowCompletions",
            "ctrl-f": "editor::Format",
            "ctrl-a": "editor::ToggleCodeActions",
            "ctrl-x": "editor::ExpandMacroRecursively",
            "ctrl-c": "copilot::Suggest",
            "ctrl-`": "copilot::NextSuggestion",
            "ctrl-left": "pane::GoBack",
            "ctrl-right": "pane::GoForward",
            "cmd-up": "vim::ScrollUp",
            "cmd-down": "vim::ScrollDown",
            "cmd-shift-up": "vim::LineUp",
            "cmd-shift-down": "vim::LineDown",
            "ctrl-shift-up": ["workspace::SendKeystrokes", "ctrl-o 5 cmd-shift-up"],
            "ctrl-shift-down": ["workspace::SendKeystrokes", "ctrl-o 5 cmd-shift-down"],
            "ctrl-shift-h": "editor::GoToDiagnostic",
            "ctrl-shift-t": "editor::GoToPreviousDiagnostic",
            "cmd-shift-w": "pane::CloseAllItems"
        }
    },
    {
        "context": "Editor",
        "bindings": {
            "alt-n": "vim::NextSubwordStart",
            "alt-right": "editor::MoveToNextWordEnd",
            "alt-d": "vim::PreviousSubwordStart",
            "alt-left": "editor::MoveToPreviousWordStart",
            "ctrl-n": "vim::NextSubwordEnd",
            "ctrl-d": "vim::PreviousSubwordEnd"
        }
    },
    {
        "context": "vim_mode == normal || vim_mode == visual",
        "bindings": {
            "s": "vim::PushSneak",
            "S": "vim::PushSneakBackward"
        }
    },
    {
        "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
        "bindings": {
            "p": "editor::Paste",
            "P": "editor::Paste",
            "x": "editor::Cut"
        }
    },
    {
        "context": "Editor && mode == full && VimControl && vim_mode != insert && !VimWaiting && !VimObject",
        "bindings": {
            "g d": "editor::GoToDefinition",
            "g shift-d": "editor::GoToDefinitionSplit",
            "g t": "editor::GoToTypeDefinition",
            "g shift-t": "editor::GoToTypeDefinitionSplit",
            "space left": "pane::SplitLeft",
            "space right": "pane::SplitRight",
            "space up": "pane::SplitUp",
            "space down": "pane::SplitDown"
        }
    },

    // Git

    {
        "context": "Editor",
        "bindings": {
            "cmd-g g": "git_panel::ToggleFocus",
            "cmd-g b": "git::Blame"
        }
    },
    {
        "context": "Editor && mode == full && !(GitDiff > Editor)",
        "bindings": {
            // "alt-shift-h": "editor::GoToHunk",
            // "alt-shift-t": "editor::GoToPreviousHunk",
            "cmd-space": "editor::ToggleSelectedDiffHunks"
            // "cmd-shift-space": "editor::ExpandAllHunkDiffs",
            // "cmd-shift-backspace": "editor::RevertSelectedHunks",
        }
    },
    {
        "context": "GitPanel",
        "bindings": {
            "cmd-space": "git::ToggleStaged"
        }
    },
    {
        "context": "Dock",
        "bindings": {
            "shift-left": "workspace::ActivatePaneLeft",
            "shift-right": "workspace::ActivatePaneRight",
            "shift-up": "workspace::ActivatePaneUp",
            "shift-down": "workspace::ActivatePaneDown"
        }
    },
    {
        "context": "VimControl",
        "bindings": {
            "-": "pane::RevealInProjectPanel"
        }
    },
    {
        "context": "Editor && vim_mode != insert",
        "bindings": {
            "shift-left": "workspace::ActivatePaneLeft",
            "shift-right": "workspace::ActivatePaneRight",
            "shift-up": "workspace::ActivatePaneUp",
            "shift-down": "workspace::ActivatePaneDown",
            "shift-alt-left": "workspace::SwapPaneLeft",
            "shift-alt-right": "workspace::SwapPaneRight",
            "shift-alt-up": "workspace::SwapPaneUp",
            "shift-alt-down": "workspace::SwapPaneDown"
        }
    },
    {
        "context": "Editor && vim_mode == insert && !VimWaiting && !VimObject",
        "bindings": {
            "cmd-enter": "vim::InsertLineAbove",
            "shift-enter": "vim::InsertLineBelow"
        }
    },
    {
        "context": "Editor && vim_mode == normal && !VimWaiting && !VimObject",
        "bindings": {
            "cmd-enter": ["workspace::SendKeystrokes", "shift-o escape"],
            "shift-enter": ["workspace::SendKeystrokes", "o escape"]
        }
    },
    {
        "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !VimObject",
        "bindings": {
            "tab": "editor::Indent",
            "shift-tab": "editor::Outdent"
        }
    },
    {
        "context": "Editor && vim_mode == normal && !VimWaiting && !VimObject && !menu",
        "bindings": {
            "enter": ["workspace::SendKeystrokes", "c i w"]
        }
    },
    {
        "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
        "bindings": {
            "enter": ["workspace::SendKeystrokes", "c"],
            "shift-s": ["vim::PushAddSurrounds", {}]
        }
    },
    {
        "context": "Editor && (vim_mode == insert || vim_mode == visual)",
        "bindings": {
            "cmd-s": ["workspace::SendKeystrokes", "escape cmd-s"]
        }
    },
    {
        "context": "BufferSearchBar",
        "bindings": {
            "alt-c": "search::ToggleCaseSensitive",
            "alt-w": "search::ToggleWholeWord",
            "alt-x": "search::ToggleRegex",
            "alt-r": "search::ToggleReplace",
            "alt-s": "search::ToggleSelection",
            "alt-i": "search::ToggleIncludeIgnored"
        }
    },
    {
        "context": "ProjectSearchBar",
        "bindings": {
            "alt-c": "search::ToggleCaseSensitive",
            "alt-w": "search::ToggleWholeWord",
            "alt-x": "search::ToggleRegex",
            "alt-r": "search::ToggleReplace",
            "alt-s": "search::ToggleSelection",
            "alt-i": "search::ToggleIncludeIgnored"
        }
    },
    {
        "context": "Diagnostics",
        "bindings": {
            "alt-w": "diagnostics::ToggleWarnings"
        }
    },
    {
        "context": "ProjectPanel",
        "bindings": {
            "left": "project_panel::CollapseSelectedEntry",
            "cmd-left": "project_panel::CollapseAllEntries",
            "right": "project_panel::ExpandSelectedEntry",
            "cmd-n": "project_panel::NewFile",
            "alt-n": "project_panel::NewDirectory",
            "cmd-x": "project_panel::Cut",
            "cmd-c": "project_panel::Copy",
            "cmd-v": "project_panel::Paste",
            "cmd-d": "project_panel::Duplicate",
            "cmd-r": "project_panel::Rename",
            "cmd-u": "project_panel::SelectParent",
            "cmd-f": "project_panel::NewSearchInDirectory",
            "alt-r": "project_panel::RevealInFileManager",
            "ctrl-c": "workspace::CopyRelativePath",
            "ctrl-shift-c": "workspace::CopyPath",
            "backspace": ["project_panel::Trash", { "skip_prompt": false }],
            "delete": ["project_panel::Trash", { "skip_prompt": false }],
            "cmd-backspace": ["project_panel::Delete", { "skip_prompt": false }],
            "cmd-delete": ["project_panel::Delete", { "skip_prompt": false }],
            "shift-down": "menu::SelectNext",
            "shift-up": "menu::SelectPrevious",
            "enter": ["workspace::SendKeystrokes", "enter cmd-shift-e"],
            "escape": "menu::Cancel",
            "cmd-shift-w": "workspace::ToggleLeftDock"
        }
    },
    {
        "context": "FileFinder || (FileFinder > Picker > Editor) || (FileFinder > Picker > menu)",
        "bindings": {
            "cmd-enter": "pane::SplitRight",
            "cmd-shift-enter": "pane::SplitDown",
            "ctrl-enter": "pane::SplitLeft",
            "ctrl-shift-enter": "pane::SplitUp"
        }
    },
    {
        "context": "AssistantPanel",
        "bindings": {
            // "cmd-h": "assistant::DeployHistory",
            "cmd-w": "workspace::ToggleRightDock",
            "cmd-shift-w": "workspace::ToggleRightDock"
        }
    },
    {
        "context": "Terminal",
        "bindings": {
            "cmd-shift-w": "workspace::ToggleBottomDock"
        }
    }
]
